if TARGET_AM335X_STAMP_NXT

config SYS_BOARD
	default "am335x_stamp_nxt"

config SYS_VENDOR
	default "calixto"

config SYS_SOC
	default "am33xx"

config SYS_CONFIG_NAME
	default "am335x_stamp_nxt"
	
config 1024DDR3
	bool "Using 512MB RAM"
	default n
	
config 512DDR3
	bool "Using 512MB RAM"
	default n
	
config 256DDR3
	bool "Using 256MB RAM"
	default n

config NOR
	bool "Support for NOR flash"
	help
	  The AM335x SoC supports having a NOR flash connected to the GPMC.
	  In practice this is seen as a NOR flash module connected to the
	  "memory cape" for the BeagleBone family.


endif
